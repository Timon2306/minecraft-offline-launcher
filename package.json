{
  "name": "minecraft-offline-launcher",
  "version": "1.1.6",
  "description": "Оффлайн-лаунчер Minecraft с Glassmorphism UI и изоляцией сборок",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --win",
    "build:native": "napi build --platform --release --manifest-path src-rust/Cargo.toml"
  },
  "author": "LauncherDev",
  "license": "MIT",
  "dependencies": {
    "minecraft-launcher-core": "^3.18.2",
    "ogl": "^1.0.11"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.2",
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.minecraft.launcher",
    "productName": "Minecraft Offline Launcher",
    "win": {
      "icon": "src/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "Timon2306",
      "repo": "minecraft-offline-launcher"
    }
  },
  "napi": {
    "name": "launcher-native",
    "triples": {
      "defaults": true,
      "additional": []
    }
  }
}
