{
  "name": "cristalix-offline-launcher",
  "version": "1.0.4",
  "description": "Оффлайн-лаунчер Minecraft с Glassmorphism UI и изоляцией сборок",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "build": "electron-builder --win"
  },
  "author": "LauncherDev",
  "license": "MIT",
  "dependencies": {
    "minecraft-launcher-core": "^3.18.2",
    "ogl": "^1.0.11"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.minecraft.launcher",
    "productName": "Minecraft Offline Launcher",
    "win": {
      "icon": "src/icon.png",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "directories": {
      "output": "dist"
    }
  }
}
